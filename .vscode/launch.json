    "version": "0.2.0",
    "configurations": [
        // {
        //     "name": "Python Debugger: Current File",
        //     "type": "debugpy",
        //     "request": "launch",
        //     "program": "${file}",
        //     "console": "integratedTerminal"
        // },
        {
          "name": "Train Qwen3-VL",
          "type": "debugpy",
          "request": "launch",
          "program": "/home/sh/anaconda3/envs/qwen3vl/bin/torchrun",
          "cwd": "${workspaceFolder}",
          "console": "integratedTerminal",
          "justMyCode": false,
        //   "subProcess": true,
          "env": {
                "CUDA_VISIBLE_DEVICES": "0",
                "NCCL_SOCKET_IFNAME": "eno1np0",
                "PYDEVD_WARN_SLOW_RESOLVE_TIMEOUT": "5.0",
                "DECORD_EOF_RETRY_MAX": "204800", 
                // "TORCH_DATALOADER_DEBUG": "1", 
                // "PYTHONFAULTHANDLER": "1", 
                // "NCCL_ASYNC_ERROR_HANDLING": "1", 
                // "NCCL_DEBUG": "INFO", 
                // "NCCL_BLOCKING_WAIT": "1",
                // "TORCH_SHOW_CPP_STACKTRACES": "1", 
                "CUDA_LAUNCH_BLOCKING": "1",
                "TORCH_DISTRIBUTED_DEBUG": "DETAIL"
          },
          "args": [
            "--nproc_per_node", "1",
            "--master_addr", "127.0.0.1",
            "--master_port", "29556",
            "qwen-vl-finetune/qwenvl/train/train_qwen_roi.py", 
            "--deepspeed", "./qwen-vl-finetune/scripts/zero2.json", 
            "--model_name_or_path", "/mnt/ssd1/sh/hf_home/Qwen3-VL-4B-Instruct", 
            "--dataset_use", "refcoco%0.1", 
            "--data_flatten", "False",
            "--tune_mm_mlp", "False",
            "--tune_mm_vision", "False",
            "--tune_mm_llm", "False",
            "--tune_roi", "True",
            "--bf16",
            "--output_dir", "./output/debug",
            "--num_train_epochs", "1.0",
            "--per_device_train_batch_size", "1",
            "--per_device_eval_batch_size", "2",
            "--gradient_accumulation_steps", "2",
            "--max_pixels", "147456",
            "--eval_strategy", "no", 
            "--save_strategy", "steps",
            "--save_steps", "500",
            "--learning_rate", "1e-5",
            "--roi_lr", "1e-3", 
            "--weight_decay", "0",
            "--warmup_ratio", "0.03",
            "--max_grad_norm", "1",
            "--lr_scheduler_type", "cosine",
            "--logging_steps", "1",
            "--model_max_length", "16384",
            "--gradient_checkpointing", "True",
            "--dataloader_num_workers", "2",
            "--run_name", "qwen3vl_debugging",
            "--report_to", "none"
          ],
        },
    ]
}